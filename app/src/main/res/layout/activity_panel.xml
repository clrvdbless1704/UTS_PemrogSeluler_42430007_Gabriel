<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="?attr/actionBarSize"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/imgLogoPanel"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@mipmap/undiknas"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/logo_desc" />

        <TextView
            android:id="@+id/tvJudulPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/panel_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvSapaan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_dosen"
            android:textSize="18sp"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etJumlahMahasiswa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/jumlah_mahasiswa_hint"
            android:inputType="number"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"/>

        <EditText
            android:id="@+id/etRataNilai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/rata_nilai_hint"
            android:inputType="number"
            android:layout_marginBottom="24dp"
            android:minHeight="48dp"/>

        <Button
            android:id="@+id/btnProses"
            android:layout_width="match_parent"
            android:maxWidth="320dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_proses"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- TEMPAT INPUT NAMA MAHASISWA -->
        <LinearLayout
            android:id="@+id/layoutMahasiswa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvAbsen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>